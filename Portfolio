<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#080c14;--bg2:#0d1420;--bg3:#111827;
  --surface:#141d2e;--surface2:#1a2540;
  --border:#1e2d45;--border2:#253554;
  --blue:#3b82f6;--blue2:#60a5fa;--blue3:#93c5fd;
  --teal:#14b8a6;--teal2:#2dd4bf;
  --amber:#f59e0b;--amber2:#fbbf24;
  --text:#f1f5f9;--text2:#94a3b8;--text3:#64748b;
  --font-display:'Syne',sans-serif;
  --font-mono:'DM Mono',monospace;
  --font-body:'DM Sans',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:15px;line-height:1.7;overflow-x:hidden;cursor:none}

/* Custom cursor */
.cursor{position:fixed;width:8px;height:8px;background:var(--blue);border-radius:50%;pointer-events:none;z-index:9999;transition:transform .1s;mix-blend-mode:screen}
.cursor-ring{position:fixed;width:32px;height:32px;border:1px solid var(--blue);border-radius:50%;pointer-events:none;z-index:9998;transition:transform .15s,width .2s,height .2s,opacity .2s;opacity:.5}
.cursor-ring.expand{width:48px;height:48px;opacity:.3}

/* Noise overlay */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");opacity:.4;pointer-events:none;z-index:1}

/* Grid lines bg */
body::after{content:'';position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:80px 80px;opacity:.15;pointer-events:none;z-index:0}

/* Nav */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:18px 48px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid transparent;transition:all .3s;backdrop-filter:blur(0)}
nav.scrolled{background:rgba(8,12,20,.85);border-bottom-color:var(--border);backdrop-filter:blur(20px)}
.nav-logo{font-family:var(--font-mono);font-size:13px;color:var(--blue2);letter-spacing:.05em}
.nav-logo span{color:var(--text3)}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{font-family:var(--font-mono);font-size:12px;color:var(--text3);text-decoration:none;letter-spacing:.08em;text-transform:uppercase;transition:color .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--blue);transition:width .3s}
.nav-links a:hover{color:var(--blue2)}
.nav-links a:hover::after{width:100%}

/* Hero */
.hero{min-height:100vh;display:flex;align-items:center;padding:0 48px;position:relative;overflow:hidden;z-index:2}
.hero-inner{max-width:1100px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 420px;gap:80px;align-items:center}
.hero-eyebrow{font-family:var(--font-mono);font-size:12px;color:var(--teal);letter-spacing:.15em;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:10px}
.hero-eyebrow::before{content:'';width:32px;height:1px;background:var(--teal)}
.hero-name{font-family:var(--font-display);font-size:clamp(44px,6vw,76px);font-weight:800;line-height:1.0;letter-spacing:-.02em;margin-bottom:16px}
.hero-name .line2{color:transparent;-webkit-text-stroke:1px var(--blue2)}
.hero-role{font-family:var(--font-display);font-size:clamp(16px,2vw,22px);font-weight:600;color:var(--text2);margin-bottom:28px;display:flex;align-items:center;gap:12px}
.hero-role .sep{color:var(--border2)}
.hero-desc{font-size:16px;color:var(--text2);line-height:1.8;max-width:520px;margin-bottom:40px;font-weight:300}
.hero-desc strong{color:var(--text);font-weight:500}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap}
.btn-primary{padding:13px 28px;background:var(--blue);color:#fff;border:none;border-radius:6px;font-family:var(--font-mono);font-size:13px;font-weight:500;cursor:none;text-decoration:none;transition:all .2s;letter-spacing:.04em;display:inline-flex;align-items:center;gap:8px}
.btn-primary:hover{background:var(--blue2);transform:translateY(-1px)}
.btn-outline{padding:13px 28px;background:transparent;color:var(--text2);border:1px solid var(--border2);border-radius:6px;font-family:var(--font-mono);font-size:13px;cursor:none;text-decoration:none;transition:all .2s;letter-spacing:.04em;display:inline-flex;align-items:center;gap:8px}
.btn-outline:hover{border-color:var(--blue);color:var(--blue2)}

/* Terminal card */
.terminal{background:var(--surface);border:1px solid var(--border2);border-radius:12px;overflow:hidden;font-family:var(--font-mono)}
.terminal-bar{background:var(--bg3);padding:12px 16px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border)}
.dot{width:11px;height:11px;border-radius:50%}
.dot-r{background:#ff5f57}.dot-y{background:#febc2e}.dot-g{background:#28c840}
.terminal-title{font-size:11px;color:var(--text3);margin:0 auto;letter-spacing:.05em}
.terminal-body{padding:20px;font-size:12.5px;line-height:2}
.t-prompt{color:var(--teal)}
.t-cmd{color:var(--text)}
.t-key{color:var(--blue2)}
.t-val{color:var(--amber2)}
.t-str{color:#86efac}
.t-comment{color:var(--text3);font-style:italic}
.t-cursor{display:inline-block;width:8px;height:14px;background:var(--blue);animation:blink .9s step-end infinite;vertical-align:middle;margin-left:2px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

/* Stats row */
.stats-strip{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:28px 48px;position:relative;z-index:2}
.stats-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:0}
.stat-item{text-align:center;padding:0 24px;border-right:1px solid var(--border)}
.stat-item:last-child{border-right:none}
.stat-num{font-family:var(--font-display);font-size:36px;font-weight:800;color:var(--blue2);line-height:1;display:block}
.stat-label{font-family:var(--font-mono);font-size:11px;color:var(--text3);letter-spacing:.08em;text-transform:uppercase;margin-top:4px;display:block}

/* Sections */
section{padding:100px 48px;position:relative;z-index:2}
.section-inner{max-width:1100px;margin:0 auto}
.section-tag{font-family:var(--font-mono);font-size:11px;color:var(--teal);letter-spacing:.15em;text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:10px}
.section-tag::before{content:'';width:24px;height:1px;background:var(--teal)}
.section-title{font-family:var(--font-display);font-size:clamp(28px,4vw,44px);font-weight:800;letter-spacing:-.02em;margin-bottom:12px;line-height:1.1}
.section-sub{font-size:16px;color:var(--text2);max-width:560px;font-weight:300;line-height:1.8;margin-bottom:56px}

/* Skills */
.skills-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.skill-cat{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:24px;transition:border-color .2s}
.skill-cat:hover{border-color:var(--border2)}
.skill-cat-label{font-family:var(--font-mono);font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.skill-cat-label::before{content:'#';color:var(--blue)}
.skill-pills{display:flex;flex-wrap:wrap;gap:8px}
.pill{font-family:var(--font-mono);font-size:11.5px;padding:5px 12px;border-radius:4px;border:1px solid;transition:all .2s;cursor:none}
.pill-blue{background:#1e3a5f22;border-color:#3b82f640;color:var(--blue3)}
.pill-blue:hover{background:#1e3a5f55;border-color:var(--blue)}
.pill-teal{background:#14b8a622;border-color:#14b8a640;color:var(--teal2)}
.pill-teal:hover{background:#14b8a644;border-color:var(--teal)}
.pill-amber{background:#f59e0b22;border-color:#f59e0b40;color:var(--amber2)}
.pill-amber:hover{background:#f59e0b44;border-color:var(--amber)}
.pill-purple{background:#7c3aed22;border-color:#7c3aed40;color:#c4b5fd}
.pill-purple:hover{background:#7c3aed44;border-color:#7c3aed}
.pill-new{position:relative}
.pill-new::after{content:'NEW';font-size:8px;position:absolute;top:-6px;right:-4px;background:var(--teal);color:#000;padding:1px 4px;border-radius:3px;font-weight:700;letter-spacing:.05em}

/* Projects */
.projects-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.proj-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:all .3s;position:relative;cursor:none}
.proj-card:hover{border-color:var(--blue);transform:translateY(-4px)}
.proj-card-accent{height:3px}
.proj-card-body{padding:28px}
.proj-number{font-family:var(--font-mono);font-size:11px;color:var(--text3);margin-bottom:12px;letter-spacing:.08em}
.proj-title{font-family:var(--font-display);font-size:20px;font-weight:700;margin-bottom:8px;line-height:1.2}
.proj-desc{font-size:13.5px;color:var(--text2);margin-bottom:16px;line-height:1.7;font-weight:300}
.proj-metrics{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
.proj-metric{font-family:var(--font-mono);font-size:11.5px;color:var(--text2);display:flex;align-items:baseline;gap:6px}
.proj-metric::before{content:'→';color:var(--blue);flex-shrink:0}
.proj-metric strong{color:var(--text);font-weight:500}
.proj-stack{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px}
.proj-tag{font-family:var(--font-mono);font-size:10.5px;padding:3px 9px;border-radius:3px;background:var(--bg3);border:1px solid var(--border2);color:var(--text3)}
.proj-links{display:flex;gap:10px}
.proj-link{font-family:var(--font-mono);font-size:11px;color:var(--text3);text-decoration:none;border:1px solid var(--border2);padding:6px 14px;border-radius:4px;transition:all .2s;display:flex;align-items:center;gap:6px;cursor:none}
.proj-link:hover{border-color:var(--blue);color:var(--blue2)}
.proj-card.ai-1 .proj-card-accent{background:linear-gradient(90deg,var(--blue),var(--teal))}
.proj-card.ai-2 .proj-card-accent{background:linear-gradient(90deg,var(--teal),#7c3aed)}
.proj-card.ai-3 .proj-card-accent{background:linear-gradient(90deg,#7c3aed,var(--amber))}
.proj-card.fs-1 .proj-card-accent{background:linear-gradient(90deg,var(--amber),var(--blue))}

/* Experience */
.exp-list{display:flex;flex-direction:column;gap:0}
.exp-item{display:grid;grid-template-columns:200px 1fr;gap:40px;padding:36px 0;border-bottom:1px solid var(--border);position:relative}
.exp-item:last-child{border-bottom:none}
.exp-date{font-family:var(--font-mono);font-size:12px;color:var(--text3);padding-top:6px;letter-spacing:.04em}
.exp-dot{position:absolute;left:196px;top:46px;width:8px;height:8px;border-radius:50%;background:var(--blue);border:2px solid var(--bg)}
.exp-company{font-family:var(--font-display);font-size:18px;font-weight:700;margin-bottom:2px}
.exp-role{font-family:var(--font-mono);font-size:12px;color:var(--blue2);margin-bottom:14px;letter-spacing:.04em}
.exp-bullets{list-style:none;display:flex;flex-direction:column;gap:8px}
.exp-bullets li{font-size:14px;color:var(--text2);display:flex;align-items:baseline;gap:10px;font-weight:300}
.exp-bullets li::before{content:'▸';color:var(--teal);flex-shrink:0;font-size:11px}
.exp-bullets strong{color:var(--text);font-weight:500}

/* Education */
.edu-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.edu-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:28px;transition:border-color .2s}
.edu-card:hover{border-color:var(--border2)}
.edu-degree{font-family:var(--font-display);font-size:16px;font-weight:700;margin-bottom:4px}
.edu-school{color:var(--blue2);font-size:14px;margin-bottom:4px;font-family:var(--font-mono);font-size:12px}
.edu-year{font-family:var(--font-mono);font-size:11px;color:var(--text3);letter-spacing:.06em}

/* Learning */
.learning-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.learn-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:18px;text-align:center;transition:all .2s}
.learn-card:hover{border-color:var(--teal);transform:translateY(-2px)}
.learn-icon{font-size:24px;margin-bottom:8px;display:block}
.learn-title{font-family:var(--font-mono);font-size:11.5px;color:var(--text2);font-weight:500;letter-spacing:.04em}

/* Contact */
.contact-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:60px;text-align:center;position:relative;overflow:hidden}
.contact-box::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,#1e3a5f20 0%,transparent 70%)}
.contact-title{font-family:var(--font-display);font-size:clamp(28px,4vw,48px);font-weight:800;letter-spacing:-.02em;margin-bottom:14px;position:relative}
.contact-sub{font-size:16px;color:var(--text2);margin-bottom:36px;font-weight:300;position:relative}
.contact-links{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;position:relative}
.contact-link{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border:1px solid var(--border2);border-radius:6px;font-family:var(--font-mono);font-size:12px;color:var(--text2);text-decoration:none;transition:all .2s;cursor:none}
.contact-link:hover{border-color:var(--blue);color:var(--blue2);background:#1e3a5f22}
.contact-link.primary{background:var(--blue);border-color:var(--blue);color:#fff}
.contact-link.primary:hover{background:var(--blue2);border-color:var(--blue2)}

/* Footer */
footer{padding:24px 48px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:relative;z-index:2}
.footer-text{font-family:var(--font-mono);font-size:11px;color:var(--text3);letter-spacing:.04em}
.footer-status{font-family:var(--font-mono);font-size:11px;color:var(--teal);display:flex;align-items:center;gap:6px}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--teal);animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(1.2)}}

/* Scroll reveal */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:none}

/* Floating orbs */
.orb{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(80px);opacity:.06}
.orb1{width:500px;height:500px;background:var(--blue);top:-100px;right:-100px;animation:drift1 18s ease-in-out infinite}
.orb2{width:400px;height:400px;background:var(--teal);bottom:-80px;left:-80px;animation:drift2 22s ease-in-out infinite}
@keyframes drift1{0%,100%{transform:translate(0,0)}50%{transform:translate(-40px,30px)}}
@keyframes drift2{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,-40px)}}

/* Mobile */
@media(max-width:768px){
  nav{padding:16px 20px}
  .nav-links{display:none}
  .hero{padding:80px 20px 60px}
  .hero-inner{grid-template-columns:1fr;gap:40px}
  .terminal{display:none}
  .stats-strip{padding:20px}
  .stats-inner{grid-template-columns:repeat(2,1fr);gap:16px}
  section{padding:60px 20px}
  .skills-grid,.projects-grid,.edu-grid{grid-template-columns:1fr}
  .learning-grid{grid-template-columns:repeat(2,1fr)}
  .exp-item{grid-template-columns:1fr;gap:8px}
  .exp-dot{display:none}
  .contact-box{padding:32px 20px}
  footer{padding:16px 20px;flex-direction:column;gap:8px}
}
</style>
</head>
